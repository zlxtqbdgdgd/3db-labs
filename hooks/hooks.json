{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude-code-hooks/user-prompt-submit.mjs\"",
            "timeout": 10,
            "statusMessage": "dbdog-obs: mint trace"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__dbdog.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude-code-hooks/pre-tool-use.mjs\"",
            "timeout": 10,
            "statusMessage": "dbdog-obs: inject trace context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude-code-hooks/stop.mjs\"",
            "timeout": 15,
            "statusMessage": "dbdog-obs: synthesize spans"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/claude-code-hooks/stop.mjs\"",
            "timeout": 15,
            "statusMessage": "dbdog-obs: synthesize spans"
          }
        ]
      }
    ]
  }
}
